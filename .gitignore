# Xcode
#
# git ignores many of these files by default.
tmp/
build/
DerivedData/
*.xcuserstate
*.xcuserdatad
xcuserdata/
*.moved-aside
*.xccheckout
*.xcscmblueprint
Package.resolved

# Swift Package Manager
#
# Add this line if you want to avoid committing the test-generated folder
.build/
/.xcodebuild-env/
**/.swiftpm/

# macOS
#
#
.DS_Store
*.swp
*~

# Python (legacy)
.venv/
__pycache__/
*.pyc

# Model conversion artifacts
**/.hf_cache/
**/mlx_output/
**/sweep_runs/
scripts/**/*.zip
scripts/**/*.tar.gz
scripts/**/*.sha256
scripts/convert_model/.env

# Test and example images
test_images/
examples/*
!examples/.gitkeep

# Antigravity
.antigravitycli/*.json
